{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "explore": {
      "mode": "subagent",
      "model": "openai/gpt-5.4-fast",
      // "model": "openai/gpt-5.3-codex-spark",
      "tools": {
        "arxiv-mcp-server*": true
      }
    },
    "general": {
      "mode": "subagent",
      "model": "openai/gpt-5.4-fast"
    }
  },
  "mcp": {
    "arxiv-mcp-server": {
      "type": "local",
      "command": ["uvx", "arxiv-mcp-server"],
      "enabled": true
    },
    "excalidraw": {
      "type": "remote",
      "url": "https://mcp.excalidraw.com",
      "enabled": true
    }
  },
  "permission": {
    "external_directory": "deny"
  }
}
